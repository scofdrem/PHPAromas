includes:
    - ./vendor/phpstan/phpstan-laravel/extension.neon

parameters:
    level: 5
    paths:
        - app
        - config
        - database
        - routes
        - tests
    excludePaths:
        - bootstrap/cache
        - vendor
        - node_modules
    checkGenericClassInNonGenericObjectType: false
    checkMissingIterableValueType: false